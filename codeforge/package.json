{
  "name": "codeforge",
  "displayName": "CodeForge - AI Programming Assistant",
  "description": "Open source AI programming assistant for developers",
  "version": "0.1.0",
  "publisher": "tinyfish",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "ai",
    "code",
    "assistant",
    "copilot",
    "codegen"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeforge.generateCode",
        "title": "%cmd.generateCode%",
        "category": "CodeForge"
      },
      {
        "command": "codeforge.explainCode",
        "title": "%cmd.explainCode%",
        "category": "CodeForge"
      },
      {
        "command": "codeforge.reviewCode",
        "title": "%cmd.reviewCode%",
        "category": "CodeForge"
      },
      {
        "command": "codeforge.refactorCode",
        "title": "%cmd.refactorCode%",
        "category": "CodeForge"
      },
      {
        "command": "codeforge.viewStats",
        "title": "%cmd.viewStats%",
        "category": "CodeForge"
      }
    ],
    "keybindings": [
      {
        "command": "codeforge.generateCode",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "codeforge.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      }
    ],
    "configuration": {
      "title": "CodeForge",
      "properties": {
        "codeforge.apiKey": {
          "type": "string",
          "default": "",
          "description": "%settings.apiKey%",
          "scope": "application"
        },
        "codeforge.model": {
          "type": "string",
          "default": "gpt-3.5-turbo",
          "enum": ["gpt-3.5-turbo", "gpt-4", "gpt-4-turbo-preview"],
          "description": "%settings.model%"
        },
        "codeforge.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "%settings.temperature%"
        },
        "codeforge.cacheEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%settings.cacheEnabled%"
        },
        "codeforge.showStats": {
          "type": "boolean",
          "default": true,
          "description": "%settings.showStats%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}